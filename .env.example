# ──────────────────────────────────────────────────────────────────────────
# Copy to `.env` for local Docker dev. On Vercel, set these in the dashboard.
# Variable names match Vercel's Postgres + Supabase integration exactly.
# ──────────────────────────────────────────────────────────────────────────

# App
NODE_ENV=development

# ── Postgres connection strings ────────────────────────────────────────────
# Local Docker: both point to the local db container (no pooler needed).
# Vercel: POSTGRES_URL is the pooled string (port 6543, transaction mode);
#         POSTGRES_URL_NON_POOLING is the direct string (port 5432) — used
#         by scripts/migrate.js so migrations run on a real session connection.
POSTGRES_URL=postgresql://postgres:your_password@db:5432/postgres
POSTGRES_PRISMA_URL=postgresql://postgres:your_password@db:5432/postgres
POSTGRES_URL_NON_POOLING=postgresql://postgres:your_password@db:5432/postgres

# ── Postgres credentials ───────────────────────────────────────────────────
# Used by the local `db` container and available as individual vars on Vercel.
POSTGRES_USER=postgres
POSTGRES_HOST=db
POSTGRES_PASSWORD=your_password
POSTGRES_DATABASE=postgres

# ── Supabase (server-side) ─────────────────────────────────────────────────
SUPABASE_URL=http://kong:8000
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret

# ── Supabase (public, client-side) ────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# ── Studio / postgres-meta (local Docker only — not used on Vercel) ───────
STUDIO_PG_META_URL=http://meta:8080
PG_META_PORT=8080
PG_META_DB_HOST=db
PG_META_DB_PORT=5432
PG_META_DB_NAME=postgres
PG_META_DB_USER=postgres
PG_META_DB_PASSWORD=your_password
